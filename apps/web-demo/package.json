{
  "name": "web-demo",
  "private": true,
  "version": "0.0.0",
  "license": "Apache-2.0",
  "description": "Demo app wiring the Gridyard packages together.",
  "type": "module",
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "build:wasm": "wasm-pack build ../../crates/gridyard-wasm --target web --out-dir ../../apps/web-demo/src/wasm-pkg --dev",
    "dev": "npm run build:wasm && vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@gridyard/grid-renderer": "*",
    "@gridyard/ui-kit": "*",
    "@gridyard/workspace-runtime": "*"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "vite": "^6.3.5"
  }
}
