#!/usr/bin/env bash
# Pre-commit: same floor as CI (see .github/workflows/ci.yml / `make check`).
# Also blocks commits on the protected default branch (main).
# Enable once per clone:  git config core.hooksPath .githooks
# Bypass in an emergency: SKIP_HOOKS=1 git commit ...

set -euo pipefail

if [ "${SKIP_HOOKS:-}" = "1" ]; then
  echo "pre-commit: SKIP_HOOKS=1 — skipping checks"
  exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"
# shellcheck source=.githooks/block-main.sh
source "$ROOT/.githooks/block-main.sh"

protected_branch="${GRIDYARD_PROTECTED_BRANCH:-main}"
current_branch="$(git symbolic-ref --quiet HEAD 2>/dev/null | sed 's|.*/||' || true)"
if [ "$current_branch" = "$protected_branch" ]; then
  block "Refusing to commit on protected branch \"${protected_branch}\"."
fi

cd "$ROOT"

red() { printf '\033[31m%s\033[0m\n' "$*"; }
green() { printf '\033[32m%s\033[0m\n' "$*"; }
step() { printf '\n→ %s\n' "$*"; }

fail() {
  red "pre-commit failed: $*"
  red "Fix the issues above, or set SKIP_HOOKS=1 to bypass once."
  exit 1
}

step "cargo fmt --all -- --check"
cargo fmt --all -- --check || fail "rustfmt"

step "cargo clippy --workspace --all-targets -- -D warnings"
cargo clippy --workspace --all-targets -- -D warnings || fail "clippy"

step "cargo test --workspace"
cargo test --workspace || fail "cargo test"

step "cargo deny check"
if ! command -v cargo-deny >/dev/null 2>&1; then
  fail "cargo-deny not installed (cargo install cargo-deny --locked)"
fi
cargo deny check || fail "cargo deny"

if [ -f package.json ]; then
  step "npm run typecheck --workspaces --if-present"
  npm run typecheck --workspaces --if-present || fail "npm typecheck"

  step "npm run lint --workspaces --if-present"
  npm run lint --workspaces --if-present || fail "npm lint"

  step "npm test --workspaces --if-present"
  npm test --workspaces --if-present || fail "npm test"

  step "npm run build --workspaces --if-present"
  npm run build --workspaces --if-present || fail "npm build"

  step "npm audit --audit-level=high"
  npm audit --audit-level=high || fail "npm audit"
fi

green "pre-commit: all checks passed"
exit 0
